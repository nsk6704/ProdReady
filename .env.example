# ProdReady — Environment Variables

# Neon PostgreSQL connection string (required)
# Get one at https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=verify-full"

# GitHub personal access token (recommended)
# Get one at https://github.com/settings/tokens (no scopes needed for public repos)
# Falls back to unauthenticated (60 req/hr) if not set
GITHUB_TOKEN=""
